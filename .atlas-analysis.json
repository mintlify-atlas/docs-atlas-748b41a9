  "keyFeatures": [
    "AI-powered disease detection using TensorFlow Lite (YOLOv11 base model) on mobile",
    "Cross-platform support: iOS, Android, and responsive web via React Native + Expo",
    "Multi-provider authentication: email/password, Google OAuth, Facebook SDK with JWT",
    "Detection history stored locally in SQLite with automatic MongoDB sync",
    "Admin web dashboard with user management, detection review, heatmaps, and KPI charts",
    "Dataset export (ZIP archive) for admin-approved detections",
    "Push notifications via Expo Notifications",
    "Image upload and storage via Cloudinary",
    "Password recovery flow via Nodemailer / SMTP",
    "Role-based access control (user vs. admin) with middleware guards"
  ],
